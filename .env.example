# Java AI Knowledge Base Starter Demo
# Usage:
#   cp .env.example .env
#   edit AI_KB_LLM_* and AI_KB_EMBEDDING_*

# Required for real RAG answers. Without real keys, the app starts but AI calls fail.
AI_KB_LLM_API_KEY=your-chat-api-key-here
AI_KB_LLM_BASE_URL=https://api.deepseek.com
AI_KB_CHAT_MODEL=deepseek-v4-flash

AI_KB_EMBEDDING_API_KEY=your-embedding-api-key-here
AI_KB_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
AI_KB_EMBEDDING_MODEL=BAAI/bge-m3

# Application and infrastructure ports exposed on the host.
APP_PORT=18080
WEB_PORT=18081
PG_PORT=15432
REDIS_PORT=16379

# Container-internal service addresses. The defaults match docker-compose.yml.
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ai_kb
SPRING_DATASOURCE_USERNAME=ai_kb
SPRING_DATASOURCE_PASSWORD=ai_kb_demo_2026
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# Demo JWT secret. Replace it if this environment is reachable by other people.
AI_KB_JWT_SECRET=change-me-in-demo-compose-default-secret-32-bytes
